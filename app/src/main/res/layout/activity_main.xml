<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:clipChildren="false"
    android:clipToPadding="false">

    <!-- BACK LAYER: Fullscreen Video Player -->
    <androidx.media3.ui.PlayerView
        android:id="@+id/player_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:use_controller="false"
        app:surface_type="surface_view"
        app:keep_content_on_player_reset="true"
        app:show_buffering="never"
        android:focusable="true"
        android:clickable="true" />

    <!-- MIDDLE LAYER: Translucent Navigation Panels -->
    <FrameLayout
        android:id="@+id/panels_container"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:visibility="gone">

        <!-- Category Panel -->
        <LinearLayout
            android:id="@+id/category_panel"
            android:layout_width="320dp"
            android:layout_height="match_parent"
            android:layout_gravity="start"
            android:orientation="vertical"
            android:background="@drawable/bg_panel"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="24dp"
            android:layout_marginStart="24dp"
            android:paddingTop="20dp"
            android:paddingBottom="20dp"
            android:elevation="12dp"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:visibility="visible">

            <!-- App Brand Logo & Title -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical|center_horizontal"
                android:paddingBottom="16dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_logo"
                    android:layout_marginEnd="12dp"
                    android:contentDescription="Logo" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_app_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/app_name"
                        android:textColor="@color/focus_blue"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.05" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Powered by bnxit.com"
                        android:textColor="@color/text_dim"
                        android:textSize="11sp"
                        android:layout_marginTop="2dp" />

                </LinearLayout>

            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp" />

            <!-- Subheading -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Categories"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="12dp"
                android:paddingBottom="4dp" />

            <androidx.leanback.widget.VerticalGridView
                android:id="@+id/rv_categories"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:paddingTop="8dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:clipToPadding="true"
                android:clipChildren="false" />

        </LinearLayout>

        <!-- Channel List Panel -->
        <LinearLayout
            android:id="@+id/channel_panel"
            android:layout_width="360dp"
            android:layout_height="match_parent"
            android:layout_gravity="start"
            android:orientation="vertical"
            android:background="@drawable/bg_panel"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="24dp"
            android:layout_marginStart="24dp"
            android:paddingTop="16dp"
            android:paddingBottom="16dp"
            android:elevation="12dp"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:visibility="gone">

            <!-- Category Header Title -->
            <TextView
                android:id="@+id/tv_category_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/all_categories"
                android:textColor="@color/text_primary"
                android:textSize="20sp"
                android:textStyle="bold"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingBottom="4dp" />

            <!-- Channel Count Badge -->
            <TextView
                android:id="@+id/tv_channel_count"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_dim"
                android:textSize="14sp"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingBottom="12dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp" />

            <androidx.leanback.widget.VerticalGridView
                android:id="@+id/rv_channels"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:paddingTop="10dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:clipToPadding="true"
                android:clipChildren="false" />

        </LinearLayout>

    </FrameLayout>

    <!-- FRONT LAYER: HUDs, Overlays & Loading -->

    <!-- Now Playing Overlay HUD (Bottom aligned) -->
    <LinearLayout
        android:id="@+id/now_playing_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:background="@drawable/bg_hud_gradient"
        android:paddingTop="48dp"
        android:paddingBottom="24dp"
        android:paddingStart="40dp"
        android:paddingEnd="40dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Pulse live badge style -->
            <TextView
                android:id="@+id/tv_now_playing_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="● LIVE"
                android:textColor="@color/live_badge_red"
                android:textSize="12sp"
                android:textStyle="bold"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="3dp"
                android:paddingBottom="3dp"
                android:background="@drawable/bg_panel"
                android:layout_marginEnd="12dp" />

            <TextView
                android:id="@+id/tv_now_playing_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/text_primary"
                android:textSize="22sp"
                android:textStyle="bold"
                android:singleLine="true"
                android:ellipsize="end"
                android:shadowColor="#80000000"
                android:shadowDx="2"
                android:shadowDy="2"
                android:shadowRadius="2" />

        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Press UP / DOWN to zap channels • Press BACK or OK for channel list"
            android:textColor="@color/text_dim"
            android:textSize="12sp"
            android:layout_marginTop="8dp"
            android:layout_marginStart="64dp" />

    </LinearLayout>

    <!-- Loading Overlay (Loader & Colorful Text Only) -->
    <LinearLayout
        android:id="@+id/loading_overlay"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="24dp"
        android:visibility="gone">

        <!-- Pulsing Ring Wrapper -->
        <FrameLayout
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:background="@drawable/bg_avatar"
            android:padding="3dp">
            <ProgressBar
                android:id="@+id/progress_bar"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:indeterminateTint="@color/focus_blue" />
        </FrameLayout>

        <TextView
            android:id="@+id/tv_loading_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="BUFFERING"
            android:textColor="@color/focus_blue"
            android:textSize="14sp"
            android:textStyle="bold"
            android:letterSpacing="0.2"
            android:layout_marginTop="20dp" />

    </LinearLayout>

    <!-- Error Overlay (Translucent centered glass card) -->
    <LinearLayout
        android:id="@+id/error_overlay"
        android:layout_width="320dp"
        android:layout_height="220dp"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@drawable/bg_panel"
        android:elevation="12dp"
        android:padding="20dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/tv_error_icon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚠"
            android:textColor="@color/error_red"
            android:textSize="36sp" />

        <TextView
            android:id="@+id/tv_error_message"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/error_stream"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginTop="8dp"
            android:gravity="center" />

        <TextView
            android:id="@+id/tv_error_retry"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/retry"
            android:textColor="@color/text_dim"
            android:textSize="13sp"
            android:layout_marginTop="12dp"
            android:gravity="center" />

    </LinearLayout>

    <!-- Player Controls Overlay (Bottom HUD for playback actions) -->
    <LinearLayout
        android:id="@+id/player_controls_hud"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:background="@drawable/bg_hud_gradient"
        android:paddingTop="48dp"
        android:paddingBottom="36dp"
        android:paddingStart="40dp"
        android:paddingEnd="40dp"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:visibility="gone">

        <!-- Controls Row -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:orientation="horizontal"
            android:clipChildren="false"
            android:clipToPadding="false">

            <!-- Menu / Channels Button (Moved to first) -->
            <TextView
                android:id="@+id/btn_menu"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="☰ CHANNELS"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:textStyle="bold"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:background="@drawable/bg_item_focus"
                android:focusable="true"
                android:clickable="true"
                android:layout_marginEnd="16dp" />

            <!-- Quality Selector Button -->
            <TextView
                android:id="@+id/btn_quality"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚙ QUALITY (Auto)"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:textStyle="bold"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:background="@drawable/bg_item_focus"
                android:focusable="true"
                android:clickable="true"
                android:layout_marginEnd="16dp" />

            <!-- Aspect Ratio Button -->
            <TextView
                android:id="@+id/btn_aspect"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📺 ASPECT (Fit)"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:textStyle="bold"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:background="@drawable/bg_item_focus"
                android:focusable="true"
                android:clickable="true"
                android:layout_marginEnd="16dp" />

            <!-- Developer Info Button -->
            <TextView
                android:id="@+id/btn_developer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ℹ DEVELOPER INFO"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:textStyle="bold"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:background="@drawable/bg_item_focus"
                android:focusable="true"
                android:clickable="true" />

        </LinearLayout>

        <!-- Hints -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:text="Press UP or BACK to return to video"
            android:textColor="@color/text_dim"
            android:textSize="12sp"
            android:layout_marginTop="16dp" />

    </LinearLayout>

    <!-- Developer Info Overlay (Modern Glass Card) -->
    <FrameLayout
        android:id="@+id/developer_info_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#E004040A"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone">

        <!-- Outer card container (modern, taller, supports tablet/TV) -->
        <FrameLayout
            android:layout_width="860dp"
            android:layout_height="520dp"
            android:layout_gravity="center"
            android:background="@drawable/bg_developer_card"
            android:elevation="20dp"
            android:padding="0dp"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:clickable="true"
            android:focusable="true">

            <!-- Top accent glow bar -->
            <View
                android:layout_width="match_parent"
                android:layout_height="3dp"
                android:layout_gravity="top"
                android:background="@color/focus_blue" />

            <!-- Close Button at Top-Right Corner -->
            <TextView
                android:id="@+id/btn_close_developer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end|top"
                android:layout_marginTop="14dp"
                android:layout_marginEnd="14dp"
                android:text="✕ CLOSE"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:textStyle="bold"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:background="@drawable/bg_item_focus"
                android:focusable="true"
                android:clickable="true" />

            <!-- Main content row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:paddingTop="36dp"
                android:paddingBottom="28dp"
                android:paddingStart="32dp"
                android:paddingEnd="32dp">

                <!-- LEFT: Profile / Identity -->
                <LinearLayout
                    android:layout_width="300dp"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center_horizontal|top">

                    <!-- Profile Photo with gradient ring -->
                    <FrameLayout
                        android:layout_width="140dp"
                        android:layout_height="140dp"
                        android:background="@drawable/bg_dev_avatar"
                        android:padding="4dp">

                        <androidx.cardview.widget.CardView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            app:cardCornerRadius="68dp"
                            app:cardBackgroundColor="#FF000000"
                            app:cardElevation="0dp"
                            app:cardPreventCornerOverlap="false">

                            <ImageView
                                android:id="@+id/iv_developer_photo"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:scaleType="centerCrop"
                                android:src="@drawable/dev_photo" />
                        </androidx.cardview.widget.CardView>
                    </FrameLayout>

                    <!-- Name -->
                    <TextView
                        android:id="@+id/tv_dev_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/dev_name"
                        android:textColor="@color/text_primary"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.02"
                        android:layout_marginTop="16dp"
                        android:gravity="center" />

                    <!-- Role -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/dev_role"
                        android:textColor="@color/focus_blue"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.15"
                        android:layout_marginTop="4dp"
                        android:gravity="center" />

                    <!-- Decorative thin divider -->
                    <View
                        android:layout_width="60dp"
                        android:layout_height="2dp"
                        android:background="@color/focus_blue"
                        android:layout_marginTop="12dp" />

                    <!-- Quick info rows -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:paddingTop="6dp"
                        android:paddingBottom="6dp"
                        android:layout_marginTop="14dp"
                        android:background="@drawable/bg_stat_card">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="✉"
                            android:textColor="@color/focus_blue"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tv_dev_email"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/dev_email"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp"
                            android:singleLine="true"
                            android:ellipsize="end"
                            android:layout_marginStart="10dp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:paddingTop="6dp"
                        android:paddingBottom="6dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_stat_card">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/dev_location"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <!-- Facebook Button -->
                    <TextView
                        android:id="@+id/btn_dev_facebook"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:background="@drawable/bg_social_btn"
                        android:paddingTop="12dp"
                        android:paddingBottom="12dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:contentDescription="@string/dev_facebook_label">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@drawable/ic_facebook"
                                android:contentDescription="Facebook" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/dev_visit_facebook"
                                android:textColor="#FFFFFFFF"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:letterSpacing="0.1"
                                android:layout_marginStart="10dp" />
                        </LinearLayout>
                    </TextView>

                    <!-- Facebook URL preview -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="facebook.com/mohiuddin.mern.dev"
                        android:textColor="@color/text_dim"
                        android:textSize="11sp"
                        android:layout_marginTop="8dp"
                        android:gravity="center" />

                </LinearLayout>

                <!-- Vertical Divider -->
                <View
                    android:layout_width="1dp"
                    android:layout_height="match_parent"
                    android:layout_marginStart="28dp"
                    android:layout_marginEnd="28dp"
                    android:background="@color/divider" />

                <!-- RIGHT: Bio / Skills / Quote (Scrollable) -->
                <ScrollView
                    android:id="@+id/bio_scrollview"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:scrollbars="vertical"
                    android:scrollbarThumbVertical="@color/focus_blue"
                    android:fadeScrollbars="false"
                    android:overScrollMode="never"
                    android:focusable="true"
                    android:clickable="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <!-- About -->
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/dev_about_title"
                            android:textColor="@color/focus_blue"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.05"
                            android:layout_marginBottom="8dp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/dev_about_body"
                            android:textColor="@color/text_primary"
                            android:textSize="13sp"
                            android:lineSpacingMultiplier="1.35"
                            android:layout_marginBottom="22dp" />

                        <!-- Stats Row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="22dp">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:paddingTop="14dp"
                                android:paddingBottom="14dp"
                                android:layout_marginEnd="8dp"
                                android:background="@drawable/bg_stat_card">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="50+"
                                    android:textColor="@color/focus_blue"
                                    android:textSize="22sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/dev_stat_projects"
                                    android:textColor="@color/text_dim"
                                    android:textSize="11sp"
                                    android:layout_marginTop="2dp" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:paddingTop="14dp"
                                android:paddingBottom="14dp"
                                android:layout_marginStart="4dp"
                                android:layout_marginEnd="4dp"
                                android:background="@drawable/bg_stat_card">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="3+ yrs"
                                    android:textColor="@color/focus_blue"
                                    android:textSize="22sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/dev_stat_experience"
                                    android:textColor="@color/text_dim"
                                    android:textSize="11sp"
                                    android:layout_marginTop="2dp" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:paddingTop="14dp"
                                android:paddingBottom="14dp"
                                android:layout_marginStart="8dp"
                                android:background="@drawable/bg_stat_card">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="100%"
                                    android:textColor="@color/focus_blue"
                                    android:textSize="22sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/dev_stat_passion"
                                    android:textColor="@color/text_dim"
                                    android:textSize="11sp"
                                    android:layout_marginTop="2dp" />
                            </LinearLayout>

                        </LinearLayout>

                        <!-- Skills -->
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/dev_skills_title"
                            android:textColor="@color/focus_blue"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.05"
                            android:layout_marginBottom="8dp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/dev_skills_body"
                            android:textColor="@color/text_secondary"
                            android:textSize="13sp"
                            android:lineSpacingMultiplier="1.4"
                            android:layout_marginBottom="22dp" />

                        <!-- Currently Building -->
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/dev_focus_title"
                            android:textColor="@color/focus_blue"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.05"
                            android:layout_marginBottom="8dp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/dev_focus_body"
                            android:textColor="@color/text_secondary"
                            android:textSize="13sp"
                            android:lineSpacingMultiplier="1.4"
                            android:layout_marginBottom="22dp" />

                        <!-- Quote -->
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@color/divider"
                            android:layout_marginBottom="16dp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/dev_quote"
                            android:textColor="@color/text_dim"
                            android:textSize="12sp"
                            android:textStyle="italic"
                            android:gravity="center" />

                    </LinearLayout>
                </ScrollView>

            </LinearLayout>

        </FrameLayout>
    </FrameLayout>

    <!-- Startup Initial Loader -->
    <LinearLayout
        android:id="@+id/startup_loader"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@color/bg_primary"
        android:visibility="visible">

        <!-- Pulsing Ring Wrapper -->
        <FrameLayout
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:background="@drawable/bg_avatar"
            android:padding="3dp">
            <ProgressBar
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:indeterminateTint="@color/focus_blue" />
        </FrameLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Loading Channels..."
            android:textColor="@color/focus_blue"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp" />
    </LinearLayout>

</FrameLayout>
