<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:clipChildren="false"
    android:clipToPadding="false">

    <!-- BACK LAYER: Fullscreen Video Player -->
    <androidx.media3.ui.PlayerView
        android:id="@+id/player_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:use_controller="false"
        app:surface_type="surface_view"
        app:keep_content_on_player_reset="true"
        app:show_buffering="never"
        android:focusable="true"
        android:clickable="true" />

    <!-- MIDDLE LAYER: Translucent Navigation Panels -->
    <FrameLayout
        android:id="@+id/panels_container"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:visibility="gone">

        <!-- Category Panel -->
        <LinearLayout
            android:id="@+id/category_panel"
            android:layout_width="320dp"
            android:layout_height="match_parent"
            android:layout_gravity="start"
            android:orientation="vertical"
            android:background="@drawable/bg_panel"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="24dp"
            android:layout_marginStart="24dp"
            android:paddingTop="20dp"
            android:paddingBottom="20dp"
            android:elevation="12dp"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:visibility="visible">

            <!-- App Brand Logo & Title -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical|center_horizontal"
                android:paddingBottom="16dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_logo"
                    android:layout_marginEnd="12dp"
                    android:contentDescription="Logo" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_app_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/app_name"
                        android:textColor="@color/focus_blue"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.05" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Powered by bnxit.com"
                        android:textColor="@color/text_dim"
                        android:textSize="11sp"
                        android:layout_marginTop="2dp" />

                </LinearLayout>

            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp" />

            <!-- Subheading -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Categories"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="12dp"
                android:paddingBottom="4dp" />

            <androidx.leanback.widget.VerticalGridView
                android:id="@+id/rv_categories"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:paddingTop="8dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:clipToPadding="true"
                android:clipChildren="false" />

        </LinearLayout>

        <!-- Channel List Panel -->
        <LinearLayout
            android:id="@+id/channel_panel"
            android:layout_width="360dp"
            android:layout_height="match_parent"
            android:layout_gravity="start"
            android:orientation="vertical"
            android:background="@drawable/bg_panel"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="24dp"
            android:layout_marginStart="24dp"
            android:paddingTop="16dp"
            android:paddingBottom="16dp"
            android:elevation="12dp"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:visibility="gone">

            <!-- Category Header Title -->
            <TextView
                android:id="@+id/tv_category_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/all_categories"
                android:textColor="@color/text_primary"
                android:textSize="20sp"
                android:textStyle="bold"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingBottom="4dp" />

            <!-- Channel Count Badge -->
            <TextView
                android:id="@+id/tv_channel_count"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_dim"
                android:textSize="14sp"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingBottom="12dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp" />

            <androidx.leanback.widget.VerticalGridView
                android:id="@+id/rv_channels"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:paddingTop="10dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:clipToPadding="true"
                android:clipChildren="false" />

        </LinearLayout>

    </FrameLayout>

    <!-- FRONT LAYER: HUDs, Overlays & Loading -->

    <!-- Now Playing Overlay HUD (Bottom aligned) -->
    <LinearLayout
        android:id="@+id/now_playing_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:background="@drawable/bg_hud_gradient"
        android:paddingTop="48dp"
        android:paddingBottom="24dp"
        android:paddingStart="40dp"
        android:paddingEnd="40dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Pulse live badge style -->
            <TextView
                android:id="@+id/tv_now_playing_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="● LIVE"
                android:textColor="@color/live_badge_red"
                android:textSize="12sp"
                android:textStyle="bold"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="3dp"
                android:paddingBottom="3dp"
                android:background="@drawable/bg_panel"
                android:layout_marginEnd="12dp" />

            <TextView
                android:id="@+id/tv_now_playing_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/text_primary"
                android:textSize="22sp"
                android:textStyle="bold"
                android:singleLine="true"
                android:ellipsize="end"
                android:shadowColor="#80000000"
                android:shadowDx="2"
                android:shadowDy="2"
                android:shadowRadius="2" />

        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Press UP / DOWN to zap channels • Press BACK or OK for channel list"
            android:textColor="@color/text_dim"
            android:textSize="12sp"
            android:layout_marginTop="8dp"
            android:layout_marginStart="64dp" />

    </LinearLayout>

    <!-- Loading Overlay (Loader & Colorful Text Only) -->
    <LinearLayout
        android:id="@+id/loading_overlay"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="24dp"
        android:visibility="gone">

        <!-- Pulsing Ring Wrapper -->
        <FrameLayout
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:background="@drawable/bg_avatar"
            android:padding="3dp">
            <ProgressBar
                android:id="@+id/progress_bar"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:indeterminateTint="@color/focus_blue" />
        </FrameLayout>

        <TextView
            android:id="@+id/tv_loading_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="BUFFERING"
            android:textColor="@color/focus_blue"
            android:textSize="14sp"
            android:textStyle="bold"
            android:letterSpacing="0.2"
            android:layout_marginTop="20dp" />

    </LinearLayout>

    <!-- Error Overlay (Translucent centered glass card) -->
    <LinearLayout
        android:id="@+id/error_overlay"
        android:layout_width="320dp"
        android:layout_height="220dp"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@drawable/bg_panel"
        android:elevation="12dp"
        android:padding="20dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/tv_error_icon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚠"
            android:textColor="@color/error_red"
            android:textSize="36sp" />

        <TextView
            android:id="@+id/tv_error_message"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/error_stream"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginTop="8dp"
            android:gravity="center" />

        <TextView
            android:id="@+id/tv_error_retry"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/retry"
            android:textColor="@color/text_dim"
            android:textSize="13sp"
            android:layout_marginTop="12dp"
            android:gravity="center" />

    </LinearLayout>

    <!-- Player Controls Overlay (Bottom HUD for playback actions) -->
    <LinearLayout
        android:id="@+id/player_controls_hud"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:background="@drawable/bg_hud_gradient"
        android:paddingTop="48dp"
        android:paddingBottom="36dp"
        android:paddingStart="40dp"
        android:paddingEnd="40dp"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:visibility="gone">

        <!-- Controls Row -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:orientation="horizontal"
            android:clipChildren="false"
            android:clipToPadding="false">

            <!-- Menu / Channels Button (Moved to first) -->
            <TextView
                android:id="@+id/btn_menu"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="☰ CHANNELS"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:textStyle="bold"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:background="@drawable/bg_item_focus"
                android:focusable="true"
                android:clickable="true"
                android:layout_marginEnd="16dp" />

            <!-- Quality Selector Button -->
            <TextView
                android:id="@+id/btn_quality"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚙ QUALITY (Auto)"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:textStyle="bold"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:background="@drawable/bg_item_focus"
                android:focusable="true"
                android:clickable="true"
                android:layout_marginEnd="16dp" />

            <!-- Aspect Ratio Button -->
            <TextView
                android:id="@+id/btn_aspect"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📺 ASPECT (Fit)"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:textStyle="bold"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:background="@drawable/bg_item_focus"
                android:focusable="true"
                android:clickable="true"
                android:layout_marginEnd="16dp" />

            <!-- Developer Info Button -->
            <TextView
                android:id="@+id/btn_developer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ℹ DEVELOPER INFO"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:textStyle="bold"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:background="@drawable/bg_item_focus"
                android:focusable="true"
                android:clickable="true" />

        </LinearLayout>

        <!-- Hints -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:text="Press UP or BACK to return to video"
            android:textColor="@color/text_dim"
            android:textSize="12sp"
            android:layout_marginTop="16dp" />

    </LinearLayout>

    <!-- Developer Info Overlay (Translucent centered glass card) -->
    <FrameLayout
        android:id="@+id/developer_info_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#D9070709"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone">

        <!-- Card container -->
        <FrameLayout
            android:layout_width="740dp"
            android:layout_height="400dp"
            android:layout_gravity="center"
            android:background="@drawable/bg_panel"
            android:elevation="16dp"
            android:padding="32dp"
            android:clipChildren="false"
            android:clipToPadding="false">

            <!-- Content Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginTop="40dp"
                android:orientation="horizontal">

                <!-- Left section (Profile Photo & info) -->
                <LinearLayout
                    android:layout_width="220dp"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:layout_marginEnd="24dp">

                    <!-- Profile Photo Container with glowing border -->
                    <FrameLayout
                        android:layout_width="106dp"
                        android:layout_height="106dp"
                        android:background="@drawable/bg_avatar"
                        android:padding="3dp"
                        android:layout_marginTop="8dp">

                        <androidx.cardview.widget.CardView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            app:cardCornerRadius="50dp"
                            app:cardBackgroundColor="#00000000"
                            app:cardElevation="0dp"
                            app:cardPreventCornerOverlap="false">

                            <ImageView
                                android:id="@+id/iv_developer_photo"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:scaleType="centerCrop"
                                android:src="@drawable/dev_photo" />
                        </androidx.cardview.widget.CardView>
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Rasedur Rahman"
                        android:textColor="@color/text_primary"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_marginTop="16dp"
                        android:gravity="center" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Full-Stack Developer"
                        android:textColor="@color/focus_blue"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_marginTop="4dp"
                        android:gravity="center" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📧 rasedul.dev@gmail.com"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp"
                        android:layout_marginTop="12dp"
                        android:gravity="center" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📍 Dhaka, Bangladesh"
                        android:textColor="@color/text_dim"
                        android:textSize="11sp"
                        android:layout_marginTop="2dp"
                        android:gravity="center" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🐙 github/khrasedul-dev"
                        android:textColor="@color/text_dim"
                        android:textSize="11sp"
                        android:layout_marginTop="2dp"
                        android:gravity="center" />

                </LinearLayout>

                <!-- Vertical Divider -->
                <View
                    android:layout_width="1dp"
                    android:layout_height="match_parent"
                    android:background="@color/divider" />

                <!-- Right section (Scrollable Bio Details) -->
                <ScrollView
                    android:id="@+id/bio_scrollview"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginStart="24dp"
                    android:layout_marginEnd="12dp"
                    android:scrollbars="vertical"
                    android:scrollbarThumbVertical="@color/focus_blue"
                    android:fadeScrollbars="false"
                    android:overScrollMode="never"
                    android:focusable="true"
                    android:clickable="true"
                    android:background="@drawable/bg_item_focus"
                    android:padding="12dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Professional Summary"
                            android:textColor="@color/focus_blue"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="6dp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Backend-focused full-stack developer with 3+ years' experience building robust backend systems, APIs, and automation. Strong in Node.js and Python (FastAPI/Flask), microservices, and cloud deployments. Fiverr Level 2 Seller with 100+ completed projects."
                            android:textColor="@color/text_primary"
                            android:textSize="13sp"
                            android:lineSpacingMultiplier="1.25"
                            android:layout_marginBottom="16dp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Core Skills"
                            android:textColor="@color/focus_blue"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="6dp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="• Languages/Frameworks: Node.js • Express • Python • FastAPI • Flask • ReactJS • Tailwind • ASP.NET\n• Databases &amp; Tools: MongoDB • Redis • SQLAlchemy • Swagger • BullMQ • Microservices\n• DevOps &amp; Cloud: Azure App Services • GitHub Actions • CI/CD Pipelines • Automation"
                            android:textColor="@color/text_secondary"
                            android:textSize="13sp"
                            android:lineSpacingMultiplier="1.3"
                            android:layout_marginBottom="16dp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Professional Experience"
                            android:textColor="@color/focus_blue"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="6dp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="• Full-Stack Developer at avares.ai (Dec 2024 – Dec 2025)\n  Contributed to full-stack product development, AI/ML features, and API pipelines.\n• Freelance Developer (Level 2 Seller) at Fiverr (2021 – Present)\n  Delivered 100+ projects worldwide specializing in bot development and scraping automation.\n• Full-Stack Developer at Collaborative Dynamics (Jan 2023 – Dec 2024)\n  Designed microservices, payment gateways, and automated workflows on Azure."
                            android:textColor="@color/text_secondary"
                            android:textSize="13sp"
                            android:lineSpacingMultiplier="1.3"
                            android:layout_marginBottom="16dp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Open Source Projects"
                            android:textColor="@color/focus_blue"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="6dp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="• jsmessengerbot: Modular Node.js Messenger bot framework with payment/admin tools.\n• jswhatsappbot: WhatsApp automation bot with custom proxy and handlers.\n• jsdiscordbot: Scalable Discord bot command manager.\n• lazy-dev: Automation toolkit for WordPress blogs, wallets, and scraping pipelines."
                            android:textColor="@color/text_secondary"
                            android:textSize="13sp"
                            android:lineSpacingMultiplier="1.3"
                            android:layout_marginBottom="16dp" />

                        <!-- Favorite Quote -->
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="“Code is like humor. When you have to explain it, it's bad.” — khrasedul"
                            android:textColor="@color/text_dim"
                            android:textSize="12sp"
                            android:textStyle="italic"
                            android:gravity="center"
                            android:layout_marginTop="4dp" />

                    </LinearLayout>
                </ScrollView>

            </LinearLayout>

            <!-- Close Button at Top-Right Corner -->
            <TextView
                android:id="@+id/btn_close_developer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end|top"
                android:layout_marginTop="0dp"
                android:layout_marginEnd="0dp"
                android:text="✕ CLOSE"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:textStyle="bold"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:background="@drawable/bg_item_focus"
                android:focusable="true"
                android:clickable="true" />

        </FrameLayout>
    </FrameLayout>

    <!-- Startup Initial Loader -->
    <LinearLayout
        android:id="@+id/startup_loader"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@color/bg_primary"
        android:visibility="visible">

        <!-- Pulsing Ring Wrapper -->
        <FrameLayout
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:background="@drawable/bg_avatar"
            android:padding="3dp">
            <ProgressBar
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:indeterminateTint="@color/focus_blue" />
        </FrameLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Loading Channels..."
            android:textColor="@color/focus_blue"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp" />
    </LinearLayout>

</FrameLayout>
