<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/channel_item_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:paddingTop="12dp"
    android:paddingBottom="12dp"
    android:layout_marginTop="6dp"
    android:layout_marginBottom="6dp"
    android:layout_marginStart="8dp"
    android:layout_marginEnd="8dp"
    android:background="@drawable/bg_item_focus"
    android:focusable="true"
    android:focusableInTouchMode="false"
    android:clickable="true"
    android:clipChildren="false"
    android:clipToPadding="false">

    <!-- Channel Initial Circle -->
    <TextView
        android:id="@+id/tv_channel_initial"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:gravity="center"
        android:textColor="@color/text_primary"
        android:textSize="16sp"
        android:textStyle="bold"
        android:background="@drawable/bg_channel_initial" />

    <!-- Channel Name -->
    <TextView
        android:id="@+id/tv_channel_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="10dp"
        android:textColor="@color/text_primary"
        android:textSize="15sp"
        android:singleLine="true"
        android:ellipsize="end" />

    <!-- Live indicator -->
    <TextView
        android:id="@+id/tv_live_dot"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="●"
        android:textColor="@color/cat_sports"
        android:textSize="8sp"
        android:visibility="gone" />

</LinearLayout>
